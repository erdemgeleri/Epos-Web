# copy .env.example .env  (veya doğrudan düzenle)

# API kök adresi (REST + SignalR). Sonda / olmasın.
# — Geliştirme: dotnet run (varsayılan 5118) veya Docker API (ör. 8081)
# — Üretim, SPA ve API ayrı sunucuda: tam adres
#   VITE_API_URL=https://api.senin-domain.com
# — Üretim, aynı domain (Nginx /api ve /hubs → backend): boş bırak, build relative path kullanır
#
# VITE_API_URL=http://localhost:5118
# VITE_API_URL=http://localhost:8081
VITE_API_URL=

# İsteğe bağlı: npm run dev sırasında proxy hedefi (VITE_API_URL boş + relative kullanımında)
# VITE_DEV_PROXY_TARGET=http://localhost:8081
